{
  "name": "ts-fire",
  "version": "0.1.2",
  "description": "A TypeScript implementation of google/python-fire — automatically generate CLIs from objects and functions",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ts-fire": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "release:tag": "node -e \"const v=require('./package.json').version; console.log('git tag v'+v+' && git push origin v'+v)\""
  },
  "keywords": [
    "cli",
    "fire",
    "python-fire",
    "typescript",
    "command-line"
  ],
  "author": "Radek Baczyński",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/radek-baczynski/ts-fire.git"
  },
  "bugs": {
    "url": "https://github.com/radek-baczynski/ts-fire/issues"
  },
  "homepage": "https://github.com/radek-baczynski/ts-fire#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
